# ============================================
# Mini RAG E-Learning Platform Configuration
# ============================================
# Copy this file to .env and fill in your values

# Gemini API Key (Required)
GEMINI_API_KEY=your-gemini-key-here

# Persistent Storage Directory (For Railway Volume, e.g. /data)
DATA_DIR=.

# Model Configuration
EMBEDDING_MODEL=models/gemini-embedding-001
LLM_MODEL=gemini-2.5-flash

# Chunking Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval Configuration
TOP_K=5
SIMILARITY_THRESHOLD=0.25

# LLM Generation
TEMPERATURE=0.3
MAX_TOKENS=2000

# Resilience & Retries
MAX_RETRIES=3
RETRY_MIN_WAIT=1.0
RETRY_MAX_WAIT=10.0

# Upload Configuration
MAX_FILE_SIZE_MB=20

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
